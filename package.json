{
  "name": "sequoia-audit",
  "version": "0.1.0",
  "description": "Open-source AI-assisted website auditor for agencies, freelancers, and product teams.",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "check": "tsc --noEmit",
    "audit": "tsx src/cli.ts"
  },
  "keywords": [
    "website-audit",
    "seo-audit",
    "accessibility",
    "ai",
    "lead-gen",
    "express",
    "typescript"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "cheerio": "^1.2.0",
    "express": "^5.2.1",
    "openai": "^6.33.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.10.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
